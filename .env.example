# ─────────────────────────────────────────────
#  AutoLunch — Environment Configuration
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── OpenRouter ──────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.0-flash-001     # Fast, cost-effective default

# ── Zomato MCP ──────────────────────────────
ZOMATO_MCP_SERVER_URL=http://localhost:3000       # Zomato MCP Node.js server
ZOMATO_AUTH_TOKEN=your_zomato_oauth_token
ZOMATO_DELIVERY_LATITUDE=28.6139                 # Your office latitude
ZOMATO_DELIVERY_LONGITUDE=77.2090                # Your office longitude
ZOMATO_MAX_DISTANCE_KM=7                         # Gold member: free delivery ≤7km
ZOMATO_MAX_BUDGET_INR=250                        # Net total cap (after all fees)
ZOMATO_MIN_RESTAURANT_RATING=4.0                 # Minimum rating filter

# ── Telegram ────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789                       # Your personal chat ID

# ── Google ──────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_JSON=./secrets/google_service_account.json
GOOGLE_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms
GOOGLE_DRIVE_FOLDER_ID=1A2B3C4D5E6F7G8H9I0J     # Drive folder for receipts

# ── App Settings ────────────────────────────
LOG_LEVEL=INFO
DATA_DIR=./data
MAX_LLM_RETRY_ATTEMPTS=3                         # Max LLM re-picks if budget exceeded
MAX_HITL_REJECTIONS=2                            # Max user rejections before "order manually"
